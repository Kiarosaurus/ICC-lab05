# Plantilla de variables de entorno para docker-compose.
# Copiar como `.env` y ajustar los valores si se desea:
#   cp .env.example .env
# (docker-compose.yml tiene estos mismos valores como defaults, así que
#  la aplicación también levanta sin crear el archivo.)
POSTGRES_USER=mundial
POSTGRES_PASSWORD=mundial123
POSTGRES_DB=mundial
